{
  "name": "tab-editor-for-ableton-live",
  "version": "0.9.0",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build:ui": "vite build",
    "build": "npm run build:ui && tsc --noEmit && tsx build.ts",
    "start": "npm run build:ui && tsx build.ts && extensions-cli run",
    "package": "npm run build && extensions-cli package -i dist-ui/index.html"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:./ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@coderline/alphatab": "^1.8.3",
    "@types/node": "^25.9.2",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.1.0"
  }

  
}
